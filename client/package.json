{
  "name": "lura-symbol-helper",
  "version": "1.0.0",
  "description": "Real-time symbol sequence sharing overlay for WoW raid coordination",
  "main": "src/main.js",
  "scripts": {
    "prebuild": "node scripts/set-server-url.js",
    "start": "electron .",
    "build": "node scripts/set-server-url.js && electron-builder --win portable",
    "build:win": "node scripts/set-server-url.js && electron-builder --win portable",
    "build:mac": "node scripts/set-server-url.js && electron-builder --mac dmg",
    "build:ci": "node scripts/set-server-url.js && electron-builder"
  },
  "build": {
    "appId": "com.lura.symbolhelper",
    "productName": "Lura Symbol Helper",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "compression": "maximum",
    "electronLanguages": ["en-US", "cs"],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png"
    },
    "portable": {
      "artifactName": "${productName}.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.games",
      "artifactName": "${productName}-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "${productName}-${arch}.dmg"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json",
      "!node_modules/**/*.md",
      "!node_modules/**/*.map",
      "!node_modules/**/*.ts",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/.github/**",
      "!node_modules/**/example/**",
      "!node_modules/**/examples/**",
      "!node_modules/**/docs/**"
    ]
  },
  "dependencies": {
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.0.12"
  },
  "overrides": {
    "glob": "^11.0.0",
    "rimraf": "^5.0.10",
    "boolean": "npm:@josephg/noop@1.0.1",
    "inflight": "npm:lru-cache@10.4.3"
  }
}
